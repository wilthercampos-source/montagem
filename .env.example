# --- Servidor ---
PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL="postgresql://montaview:montaview@localhost:5432/montaview_enterprise?schema=public"

# --- Autenticação ---
JWT_SECRET="troque-esta-chave-em-producao-por-um-valor-aleatorio-longo"
